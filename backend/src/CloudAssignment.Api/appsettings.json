{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=cloud_assignment_v3;Username=cloud_assignment;Password=change-me-local-only"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173"
    ]
  },
  "Jwt": {
    "Issuer": "cloud-assignment-v3",
    "Audience": "cloud-assignment-web",
    "SigningKey": "replace-this-with-a-secret-at-least-32-characters-long",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  },
  "RefreshCookie": {
    "Name": "cloud_assignment_refresh",
    "Secure": true,
    "SameSite": "None"
  },
  "Database": {
    "ApplyMigrationsOnStartup": true
  },
  "Seed": {
    "Enabled": false,
    "DefaultPassword": "replace-in-environment"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*"
}
